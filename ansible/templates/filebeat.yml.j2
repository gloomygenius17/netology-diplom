filebeat.inputs:
- type: log
  enabled: true
  paths:
    - /var/log/nginx/access.log
  fields:
    log_type: nginx_access
    host: {{ ansible_hostname }}

- type: log
  enabled: true
  paths:
    - /var/log/nginx/error.log
  fields:
    log_type: nginx_error
    host: {{ ansible_hostname }}

output.elasticsearch:
  hosts: ["{{ elasticsearch_host }}:9200"]
  indices:
    - index: "nginx-logs-%{+yyyy.MM.dd}"
